# Copy this file to .env and fill in the values before running docker-compose.
# Never commit .env to source control.
# scripts/run-dev.* and scripts/reset-dev-db.* auto-generate JWT_SECRET and FCAPTCHA_SECRET
# into .env (local only). reset-dev-db rolls FCAPTCHA_SECRET each time.

# JWT signing secret — must be at least 32 characters, cryptographically random.
# Generate with: openssl rand -base64 48
JWT_SECRET=replace-with-a-long-random-secret

# PostgreSQL — local dev uses fixed credentials (postgres / postgres)
POSTGRES_PASSWORD=postgres

# Host port for Docker Postgres (maps to container 5432).
# Default 5434 avoids conflict with local PostgreSQL installs on 5432/5433.
POSTGRES_HOST_PORT=5434

# FCaptcha shared secret — must match the fcaptcha container and backend FCaptcha__Secret.
# Generate with: openssl rand -base64 48
FCAPTCHA_SECRET=replace-with-a-long-random-secret

# Host port for Docker FCaptcha (maps to container 3000).
FCAPTCHA_HOST_PORT=3010

# Dev cluster environment label stored on tenant registry rows.
TENANCY_CLUSTER_ENVIRONMENT=dev

# Optional Docker resource overrides. With no profile, the five lightweight
# services are capped at about 1.25 GiB. `antivirus` raises that to about 3.75
# GiB; `ai` raises it to about 2.75 GiB. Do not enable both on an 8 GiB machine.
# POSTGRES_MEMORY_LIMIT=512m
# POSTGRES_CPUS=1.0
# FCAPTCHA_MEMORY_LIMIT=96m
# FCAPTCHA_CPUS=0.25
# REDIS_MEMORY_LIMIT=96m
# REDIS_CPUS=0.25
# CLAMAV_MEMORY_LIMIT=2560m
# CLAMAV_CPUS=0.75
# LLM_MEMORY_LIMIT=1536m
# LLM_CPUS=1.5
# BACKEND_MEMORY_LIMIT=512m
# BACKEND_CPUS=1.0
# FRONTEND_MEMORY_LIMIT=48m
# FRONTEND_CPUS=0.25

# Ollama concurrency controls. Raising these increases RAM use, especially when
# multiple models or parallel contexts are resident at once.
# OLLAMA_MAX_LOADED_MODELS=1
# OLLAMA_NUM_PARALLEL=1
# OLLAMA_MAX_QUEUE=32
# OLLAMA_KEEP_ALIVE=2m

# The 0.6B model is sufficient for bounded ticket evidence classification and
# is about one third the size of the former 1.7B default.
# LLM_CHAT_MODEL=qwen3:0.6b
# LLM_EMBED_MODEL=nomic-embed-text

# Deterministic ticket confidence bounds. The model cannot bypass these values.
# TICKET_AI_INITIAL_SCORE=0.5
# TICKET_AI_MAX_DELTA=0.15
# TICKET_AI_MAX_MESSAGE_CHARACTERS=2000
# TICKET_STUDENT_CONFIDENCE_THRESHOLD=0.75
# TICKET_REVIEWER_AUDIT_RATE=0.10
# TICKET_REVIEWER_BLEND_WEIGHT=0.70
