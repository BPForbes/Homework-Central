# Copy this file to .env and fill in the values before running docker-compose.
# Never commit .env to source control.
# scripts/run-dev.* and scripts/reset-dev-db.* auto-generate JWT_SECRET and FCAPTCHA_SECRET
# into .env (local only). reset-dev-db rolls FCAPTCHA_SECRET each time.

# JWT signing secret — must be at least 32 characters, cryptographically random.
# Generate with: openssl rand -base64 48
JWT_SECRET=replace-with-a-long-random-secret

# PostgreSQL — local dev uses fixed credentials (postgres / postgres)
POSTGRES_PASSWORD=postgres

# Host port for Docker Postgres (maps to container 5432).
# Default 5434 avoids conflict with local PostgreSQL installs on 5432/5433.
POSTGRES_HOST_PORT=5434

# FCaptcha shared secret — must match the fcaptcha container and backend FCaptcha__Secret.
# Generate with: openssl rand -base64 48
FCAPTCHA_SECRET=replace-with-a-long-random-secret

# Host port for Docker FCaptcha (maps to container 3000).
FCAPTCHA_HOST_PORT=3010

# Dev cluster environment label stored on tenant registry rows.
TENANCY_CLUSTER_ENVIRONMENT=dev
