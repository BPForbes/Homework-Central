{
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5433;Database=homework_central;Username=postgres;Password=postgres"
  },
  "Jwt": {
    "Issuer": "HomeworkCentral",
    "Audience": "HomeworkCentralUsers",
    "AccessTokenMinutes": "15",
    "RefreshTokenDays": "7"
  },
  "Cors": {
    "AllowedOrigin": "http://localhost:5173"
  },
  "IpRateLimiting": {
    "EnableEndpointRateLimiting": true,
    "StackBlockedRequests": false,
    "HttpStatusCode": 429,
    "GeneralRules": [
      {
        "Endpoint": "POST:/api/auth/login",
        "Period": "5m",
        "Limit": 10
      },
      {
        "Endpoint": "POST:/api/auth/register",
        "Period": "1h",
        "Limit": 5
      }
    ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
