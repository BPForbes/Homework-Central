{
  "FCaptcha": {
    "ServerUrl": "http://localhost:3010"
  },
  "ConnectionStrings": {
    // run-dev starts only Postgres + FCaptcha; blank Redis so Program.cs falls back to the
    // in-memory distributed cache. Docker deployments override via ConnectionStrings__Redis.
    "Redis": ""
  },
  "ClamAv": {
    // run-dev starts the clamav container (docker-compose.yml) on localhost:3310. Scans
    // fail open (NotScanned) while clamd is still loading signatures or not running.
    "Enabled": true
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Information",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  }
}
