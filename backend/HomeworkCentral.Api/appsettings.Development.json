{
  "FCaptcha": {
    "ServerUrl": "http://localhost:3010"
  },
  "ConnectionStrings": {
    // run-dev starts only Postgres + FCaptcha; blank Redis so Program.cs falls back to the
    // in-memory distributed cache. Docker deployments override via ConnectionStrings__Redis.
    "Redis": ""
  },
  "ClamAv": {
    // run-dev starts the clamav container (docker-compose.yml, localhost:3310) only when
    // HC_ENABLE_CLAMAV=1 — clamd keeps ~1.2-1.5g of signatures resident, a lot on small
    // machines. Scans fail open (NotScanned) while clamd is loading or not running, so
    // leaving this true is safe either way.
    "Enabled": true
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Information",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  }
}
