# Prefer explicit types instead of var in C#.
# See docs/COMMENT_STANDARD.md.
[*.cs]
csharp_style_var_for_built_in_types = false:error
csharp_style_var_when_type_is_apparent = false:error
csharp_style_var_elsewhere = false:error

[*.{cs,ts,tsx,js,jsx,json,yml,yaml,md,css,html,sh,ps1}]
charset = utf-8
insert_final_newline = true
trim_trailing_whitespace = true

[*.{cs,ts,tsx,js,jsx}]
indent_style = space
indent_size = 4

[*.{yml,yaml,json}]
indent_style = space
indent_size = 2
