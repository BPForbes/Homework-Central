{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build-dev-stack",
      "command": "dotnet",
      "type": "process",
      "args": [
        "build",
        "${workspaceFolder}/HomeworkCentral.sln",
        "-c",
        "Debug"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": "$msCompile"
    },
    {
      "label": "run-dev-stack",
      "type": "shell",
      "command": "${workspaceFolder}/scripts/run-dev.sh",
      "options": {
        "env": {
          "HC_SKIP_DOTNET_BUILD": "1"
        }
      },
      "windows": {
        "command": "pwsh",
        "args": [
          "-NoProfile",
          "-ExecutionPolicy",
          "Bypass",
          "-File",
          "${workspaceFolder}/scripts/run-dev.ps1"
        ],
        "options": {
          "env": {
            "HC_SKIP_DOTNET_BUILD": "1"
          }
        }
      },
      "isBackground": true,
      "dependsOn": ["build-dev-stack"],
      "problemMatcher": {
        "owner": "homework-central",
        "pattern": {
          "regexp": "."
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^==>",
          "endsPattern": "Dev stack is running in separate terminals"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      }
    }
  ]
}
