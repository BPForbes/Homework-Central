# .NET
bin/
obj/
*.user
*.suo
.vs/
*.swp

# EF Core scaffolding artifacts (migrations are hand-authored; see scripts/ef-migrations-add.sh)
**/Migrations/*.Designer.cs
**/Migrations/*ModelSnapshot.cs

# Node
node_modules/
dist/
.vite/

# Local env overrides (never commit secrets)
appsettings.Local.json
.env
.env.local
.env.*.local
.hc-dev-stack.state

# AI tooling (local only, per SETUP.md)
.codegraph/
.code-review-graph/
claude-mem/

# SonarQube / SonarScanner local caches (CI installs under .sonar/scanner)
.sonar/
.scannerwork/

# SonarQube for IDE binding may include secrets in local overrides; commit only
# connectedMode.json after copying from connectedMode.example.json (no tokens).
.sonarlint/*
!.sonarlint/connectedMode.example.json
!.sonarlint/connectedMode.json

# OS
.DS_Store
Thumbs.db

# Local postgres volume password (generated by dev scripts)
.postgres-volume-password
